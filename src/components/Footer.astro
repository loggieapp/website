---
---

<footer>
  <div class="container">
    <span class="logo">Loggie</span>
    <p>&copy; {new Date().getFullYear()} Loggie. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
  }

  .container {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  p {
    font-size: 0.875rem;
    color: var(--text-faint);
  }

  @media (max-width: 640px) {
    .container {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
