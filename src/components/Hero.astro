---
---

<section class="hero">
  <div class="hero-content">
    <div class="badge">
      <span class="badge-dot"></span>
      Available for macOS & Windows
    </div>

    <h1>
      Your personal<br />
      <span class="gradient-text">activity memory</span>
    </h1>

    <p class="subtitle">
      Loggie quietly tracks what you do on your computer and stores everything
      locally. Ask an AI about your day — it remembers so you don't have to.
    </p>

    <div class="actions">
      <div class="download-buttons">
        <a href="https://api.loggie.app/releases/macos/latest/download" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.99 2.97 12.5 4.7 9.47C5.55 7.97 7.13 7.01 8.82 6.99C10.1 6.97 11.32 7.85 12.11 7.85C12.89 7.85 14.37 6.78 15.92 6.95C16.57 6.98 18.39 7.21 19.56 8.91C19.47 8.97 17.09 10.35 17.12 13.18C17.15 16.59 20.09 17.73 20.12 17.74C20.09 17.81 19.64 19.29 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"></path>
          </svg>
          Download for macOS
        </a>
        <a href="https://api.loggie.app/releases/windows/latest/download" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 5.557L10.95 4.5L10.953 12.15L3.006 12.197L3 5.557ZM10.942 12.83L10.955 20.494L3.005 19.437L3.005 12.783L10.942 12.83ZM11.89 4.37L21 3V12.057L11.89 12.132L11.89 4.37ZM21.001 12.87L21 21.993L11.89 20.623L11.875 12.86L21.001 12.87Z"></path>
          </svg>
          Download for Windows
        </a>
      </div>
      <a href="#how-it-works" class="btn btn-secondary">Learn more</a>
    </div>
  </div>

  <div class="blob blob-pink"></div>
  <div class="blob blob-green"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 6rem;
    text-align: center;
  }

  .hero-content {
    max-width: 48rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: #f5f5f5;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--brand-green);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--brand-pink), var(--brand-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    max-width: 32rem;
    margin: 1.5rem auto 0;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .download-buttons {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--text);
    color: white;
  }

  .btn-primary:hover {
    background: #262626;
  }

  .btn-secondary {
    border: 1px solid #e5e5e5;
    color: #404040;
  }

  .btn-secondary:hover {
    background: #fafafa;
  }

  .blob {
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
    filter: blur(80px);
  }

  .blob-pink {
    top: -10rem;
    left: 50%;
    transform: translateX(-50%);
    width: 36rem;
    height: 36rem;
    background: var(--brand-pink);
    opacity: 0.15;
  }

  .blob-green {
    top: -5rem;
    left: 33%;
    width: 24rem;
    height: 24rem;
    background: var(--brand-green);
    opacity: 0.12;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 6rem 1.5rem 4rem;
    }
  }
</style>
