---
---

<section class="hero">
  <div class="hero-content">
    <div class="badge">
      <span class="badge-dot"></span>
      Available for macOS & Windows
    </div>

    <h1>
      Your personal<br />
      <span class="gradient-text">activity memory</span>
    </h1>

    <p class="subtitle">
      Loggie quietly tracks what you do on your computer and stores everything
      locally. Ask an AI about your day — it remembers so you don't have to.
    </p>

    <div class="actions">
      <a href="#download" class="btn btn-primary">Download</a>
      <a href="#how-it-works" class="btn btn-secondary">Learn more</a>
    </div>
  </div>

  <div class="blob blob-pink"></div>
  <div class="blob blob-green"></div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 6rem;
    text-align: center;
  }

  .hero-content {
    max-width: 48rem;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: #f5f5f5;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: var(--brand-green);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--brand-pink), var(--brand-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    max-width: 32rem;
    margin: 1.5rem auto 0;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .btn {
    display: inline-flex;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--text);
    color: white;
  }

  .btn-primary:hover {
    background: #262626;
  }

  .btn-secondary {
    border: 1px solid #e5e5e5;
    color: #404040;
  }

  .btn-secondary:hover {
    background: #fafafa;
  }

  .blob {
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
    filter: blur(80px);
  }

  .blob-pink {
    top: -10rem;
    left: 50%;
    transform: translateX(-50%);
    width: 36rem;
    height: 36rem;
    background: var(--brand-pink);
    opacity: 0.15;
  }

  .blob-green {
    top: -5rem;
    left: 33%;
    width: 24rem;
    height: 24rem;
    background: var(--brand-green);
    opacity: 0.12;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 6rem 1.5rem 4rem;
    }
  }
</style>
