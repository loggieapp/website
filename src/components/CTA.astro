<style>
  .cta {
    background: #1D2025;
    padding: 7rem 2.5rem 6rem;
    text-align: center;
  }

  .inner {
    max-width: 40rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  h2 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: #F9F8F4;
  }

  p {
    font-size: 1rem;
    font-weight: 300;
    color: rgba(249, 248, 244, 0.55);
    line-height: 1.6;
  }

  .buttons {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.625rem;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: inherit;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-lime {
    background: #B8A4DF;
    color: #1D2025;
  }

  .btn-lime:hover {
    background: #cbbaf0;
    transform: translateY(-2px);
  }

  .btn-ghost {
    border: 1.5px solid rgba(249, 248, 244, 0.25);
    color: #F9F8F4;
    background: transparent;
  }

  .btn-ghost:hover {
    border-color: rgba(249, 248, 244, 0.6);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .cta { padding: 5rem 1.5rem 4rem; }
  }
</style>
