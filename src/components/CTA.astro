<section class="cta-section" id="download">
  <div class="container">
    <div class="card fade-in">
      <h2>Ready to remember everything?</h2>
      <p>Download Loggie for free. Your data stays on your machine, always.</p>
      <div class="buttons">
        <a href="#" class="btn btn-macos">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.99 2.97 12.5 4.7 9.47C5.55 7.97 7.13 7.01 8.82 6.99C10.1 6.97 11.32 7.85 12.11 7.85C12.89 7.85 14.37 6.78 15.92 6.95C16.57 6.98 18.39 7.21 19.56 8.91C19.47 8.97 17.09 10.35 17.12 13.18C17.15 16.59 20.09 17.73 20.12 17.74C20.09 17.81 19.64 19.29 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"
            ></path>
          </svg>
          macOS
        </a>
        <a href="#" class="btn btn-windows">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M3 5.557L10.95 4.5L10.953 12.15L3.006 12.197L3 5.557ZM10.942 12.83L10.955 20.494L3.005 19.437L3.005 12.783L10.942 12.83ZM11.89 4.37L21 3V12.057L11.89 12.132L11.89 4.37ZM21.001 12.87L21 21.993L11.89 20.623L11.875 12.86L21.001 12.87Z"
            ></path>
          </svg>
          Windows
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 6rem 1.5rem;
  }

  .container {
    max-width: 48rem;
    margin: 0 auto;
  }

  .card {
    background: var(--text);
    border-radius: 1.5rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: white;
  }

  .card > p {
    margin-top: 1rem;
    color: #a3a3a3;
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
  }

  .buttons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn-macos {
    background: white;
    color: var(--text);
  }

  .btn-macos:hover {
    background: #f5f5f5;
  }

  .btn-windows {
    border: 1px solid #404040;
    color: white;
  }

  .btn-windows:hover {
    background: #1a1a1a;
  }
</style>
